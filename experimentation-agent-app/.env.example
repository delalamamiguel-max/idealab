# =============================================================
# Experimentation Agent — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Then edit .env with your API key.
# =============================================================

# OpenAI API Key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model to use (optional — defaults to gpt-4o)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Temperature (optional — defaults to 0.4)
# Lower = more deterministic, Higher = more creative
OPENAI_TEMPERATURE=0.4

# =============================================================
# Telecom Market Intelligence (optional)
# =============================================================

# Apify API Token — required for live scraping mode
# Get yours at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your-token-here

# Apify base URL (optional — defaults to https://api.apify.com/v2)
APIFY_BASE_URL=https://api.apify.com/v2

# Classification model (optional — defaults to gpt-4o-mini for cost efficiency)
# Used by the LLM-powered Classification Agent
CLASSIFICATION_MODEL=gpt-4o-mini

# Signal cache TTL in seconds (optional — defaults to 3600 = 1 hour)
SIGNAL_CACHE_TTL=3600
